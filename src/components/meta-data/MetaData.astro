---
// Import the global.css file here
import "../../styles/reset.css";
import "../../styles/global.css";
import "chop-logic-components/styles/main";
import { mapStructuredDataToJsonLdHtml } from "../../lib/content/mappers";
import type { MetaData } from "../../lib/content/models";

interface Props {
	siteTitle: string;
	metaData: MetaData;
}

const { siteTitle, metaData } = Astro.props;

const {
	metaTitle,
	metaDescription,
	keywords,
	canonicalURL,
	authorName,
	robots,
	structuredData,
	openGraph,
} = metaData;
const { ogDescription, ogTitle, ogType, ogImage } = openGraph;

const siteRoot = new URL(Astro.url.origin); // TODO: Astro.site when available for production canonicals
const canonical = canonicalURL ?? new URL(Astro.url.pathname, siteRoot);
const ogImageUrl = new URL(ogImage.src, Astro.url);
const rssUrl = new URL("rss.xml", siteRoot);

const structuredDataJsonLd = mapStructuredDataToJsonLdHtml(structuredData);
const hasOgWidth = ogImage.width != null && ogImage.width > 0;
const hasOgHeight = ogImage.height != null && ogImage.height > 0;
const hasKeywords = !!keywords;
const hasAuthorName = !!authorName;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={siteTitle}
	href={rssUrl}
/>

<!-- Font preloads -->
<link
	rel="preload"
	href="/fonts/Chopin-Bold.woff2"
	as="font"
	type="font/woff2"
	crossorigin
/>
<link
	rel="preload"
	href="/fonts/Chopin-Regular.woff2"
	as="font"
	type="font/woff2"
	crossorigin
/>
<link
	rel="preload"
	href="/fonts/FliegeMono-Regular.woff2"
	as="font"
	type="font/woff2"
	crossorigin
/>

<!-- Primary Meta Tags -->
<link rel="canonical" href={canonical} />
<title>{metaTitle}</title>
<meta name="title" content={metaTitle} />
<meta name="description" content={metaDescription} />
<meta name="robots" content={robots} />
{hasKeywords && <meta name="keywords" content={keywords} />}
{hasAuthorName && <meta name="author" content={authorName} />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={ogTitle ?? metaTitle} />
<meta property="og:description" content={ogDescription ?? metaDescription} />
<meta property="og:image" content={ogImageUrl} />
{
	hasOgWidth && (
		<meta property="og:image:width" content={String(ogImage.width)} />
	)
}
{
	hasOgHeight && (
		<meta property="og:image:height" content={String(ogImage.height)} />
	)
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={ogTitle ?? metaTitle} />
<meta name="twitter:description" content={ogDescription ?? metaDescription} />
<meta name="twitter:image" content={ogImageUrl} />

{
	structuredDataJsonLd && (
		<script
			is:inline
			type="application/ld+json"
			set:html={structuredDataJsonLd}
		/>
	)
}
