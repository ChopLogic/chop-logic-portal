---
// Import the global.css file here so that it is included on
// all pages through the use of the <MetaData /> component.
import "../../styles/global.css";
import type { ImageMetadata } from "astro";
import FallbackImage from "../../assets/blog-placeholder-1.jpg";

interface Props {
	// Global Settings
	siteTitle: string;

	// Meta SEO
	metaTitle: string;
	metaDescription: string;
	authorName?: string;
	keywords?: string;
	canonicalURL?: string;
	robots?: string;

	// Open Graph
	ogType?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogImage?: ImageMetadata;
}

const {
	siteTitle,
	metaTitle,
	metaDescription,
	keywords,
	authorName,
	canonicalURL,
	robots = "index, follow",
	ogType = "website",
	ogTitle,
	ogDescription,
	ogImage = FallbackImage,
} = Astro.props;

const siteRoot = new URL(Astro.url.origin); // TODO: Replace with siteRoot = Astro.site ?? new URL(Astro.url.origin) when Astro.site is available
const canonical = canonicalURL ?? new URL(Astro.url.pathname, siteRoot);
const ogImageURL = new URL(ogImage.src, Astro.url);
const rssURL = new URL("rss.xml", siteRoot);
const hasAuthor = !!authorName && authorName.trim() !== "";
const hasKeywords = !!keywords && keywords.trim() !== "";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={siteTitle}
	href={rssURL}
/>

<!-- Font preloads -->
<link
	rel="preload"
	href="/fonts/atkinson-regular.woff"
	as="font"
	type="font/woff"
	crossorigin
/>
<link
	rel="preload"
	href="/fonts/atkinson-bold.woff"
	as="font"
	type="font/woff"
	crossorigin
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Primary Meta Tags -->
<title>{metaTitle}</title>
<meta name="title" content={metaTitle} />
<meta name="description" content={metaDescription} />
<meta name="robots" content={robots} />
{hasKeywords && <meta name="keywords" content={keywords} />}
{hasAuthor && <meta name="author" content={authorName} />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={ogTitle ?? metaTitle} />
<meta property="og:description" content={ogDescription ?? metaDescription} />
<meta property="og:image" content={ogImageURL} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={ogTitle ?? metaTitle} />
<meta name="twitter:description" content={ogDescription ?? metaDescription} />
<meta name="twitter:image" content={ogImageURL} />
