---
import type { DynamicZoneEmbeddedVideo } from "../../lib/content/models/dynamic-zone";
import Link from "../link/Link.astro";
import { resolveEmbedVideoSource } from "./embed-video";

interface Props {
	embeddedVideo: DynamicZoneEmbeddedVideo;
}

const { embeddedVideo } = Astro.props;
const { heading, subHeading, link } = embeddedVideo;
const embed = resolveEmbedVideoSource(link.url);
const iframeTitle = link.text || heading;
---

<section
	class:list={[
		"zone-embedded-video",
		embed && `zone-embedded-video--${embed.provider}`,
	]}
>
	<h2>{heading}</h2>
	{subHeading && <h3>{subHeading}</h3>}
	{
		embed ? (
			<div class="zone-embedded-video-player">
				<iframe
					src={embed.embedUrl}
					title={iframeTitle}
					loading="lazy"
					referrerpolicy={link.referrerpolicy}
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
					allowfullscreen
				/>
			</div>
		) : (
			<p class="zone-embedded-video-fallback">
				This video cannot be embedded.
				<Link link={link}>Watch {link.text}</Link>
			</p>
		)
	}
</section>

<style>
	.zone-embedded-video {
		margin-block: 2rem;
	}

	.zone-embedded-video h2 {
		margin: 0 0 0.35em;
	}

	.zone-embedded-video h3 {
		margin: 0 0 1rem;
		font-weight: normal;
		color: rgb(var(--gray));
	}

	.zone-embedded-video-player {
		position: relative;
		width: 100%;
		max-width: 960px;
		margin-inline: auto;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: 12px;
		background: rgb(var(--gray-dark));
		box-shadow: var(--box-shadow);
	}

	.zone-embedded-video-player iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}

	.zone-embedded-video-fallback {
		margin: 0;
		padding: 1rem 1.25rem;
		border-radius: 12px;
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
	}

	.zone-embedded-video-fallback :global(a) {
		margin-left: 0.35em;
		color: var(--cl-accent-a0);
	}
</style>
