---
import { DEFAULT_SITE_TITLE } from "../../constants/defaults";
import Layout from "../../layouts/BlogPost.astro";
import { ArticleNotFoundError } from "../../lib/content/errors";
import { createContentProvider } from "../../lib/content/provider";

export async function getStaticPaths() {
	const content = createContentProvider();
	const { articles, siteConfig } = await content.getBlogIndexContent();
	const siteTitle =
		siteConfig.siteTitle.trim() !== ""
			? siteConfig.siteTitle.trim()
			: DEFAULT_SITE_TITLE;
	const paths = await Promise.all(
		articles.map(async (summary) => {
			try {
				const detail = await content.getArticleBySlug(summary.slug, siteTitle);
				return {
					params: { slug: summary.slug },
					props: { detail, siteConfig },
				};
			} catch (e) {
				if (e instanceof ArticleNotFoundError) {
					return null;
				}
				throw e;
			}
		}),
	);
	return paths.filter((p): p is NonNullable<typeof p> => p !== null);
}

const { detail, siteConfig } = Astro.props;
const siteTitle = siteConfig.siteTitle || DEFAULT_SITE_TITLE;
---

<Layout
	siteTitle={siteTitle}
	metaData={detail.metaData}
	title={detail.title}
	pubDate={detail.pubDate}
	updatedDate={detail.updatedDate}
	heroImageUrl={detail.heroImageUrl}
	heroImageAlt={detail.heroImageAlt}
>
	<div class="article-body cms-body" set:html={detail.bodyHtml} />
</Layout>

<style>
	.article-body :global(.cms-picture img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
	}
	.article-body :global(section) {
		margin-bottom: 1.5rem;
	}
</style>
