---
import Layout from "../../layouts/DynamicContentPage.astro";
import { createContentProvider } from "../../lib/content/provider";

const provider = createContentProvider();
const { siteConfig, page, articles } = await provider.getBlogPageContent();
console.log("articles", articles);
const { siteTitle, footer, links } = siteConfig;
const { title, subTitle, content, metaData, documentId, slug, updatedAt } =
	page;
---

<Layout
	siteTitle={siteTitle}
	footer={footer}
	links={links}
	title={title}
	subTitle={subTitle}
	content={content}
	metaData={metaData}
	documentId={documentId}
	slug={slug}
	updatedAt={updatedAt}
/>
