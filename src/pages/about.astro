---
import { DEFAULT_SITE_TITLE } from "../constants/defaults";
import Layout from "../layouts/BlogPost.astro";
import { createContentProvider } from "../lib/content/provider";

const content = createContentProvider();
const { page, siteConfig } = await content.getAboutPageContent();
const siteTitle = siteConfig.siteTitle || DEFAULT_SITE_TITLE;
---

<Layout
	siteTitle={siteTitle}
	metaData={page.metaData}
	title={page.heading}
	pubDate={page.publishedAt ?? new Date()}
	heroImageUrl={page.heroImageUrl}
	heroImageAlt={page.heroImageAlt}
>
	{page.subHeading && <p>{page.subHeading}</p>}
	<div class="cms-body" set:html={page.bodyHtml} />
</Layout>

<style>
	.cms-body :global(.cms-picture img) {
		max-width: 100%;
		height: auto;
		border-radius: 12px;
	}
</style>
