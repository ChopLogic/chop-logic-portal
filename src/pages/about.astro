---
import Layout from "../layouts/BlogPost.astro";
import { createContentProvider } from "../lib/content/provider";

const content = createContentProvider();
const page = await content.getSingleton("about-me");
---

<Layout
	title={page.metaData.metaTitle}
	description={page.metaData.metaDescription}
	pubDate={page.publishedAt ?? new Date()}
	heroImageUrl={page.heroImageUrl}
	heroImageAlt={page.heroImageAlt}
>
	<h2>{page.heading}</h2>
	{page.subHeading && <p>{page.subHeading}</p>}
	<div class="cms-body" set:html={page.bodyHtml} />
</Layout>

<style>
	.cms-body :global(.cms-picture img) {
		max-width: 100%;
		height: auto;
		border-radius: 12px;
	}
</style>
