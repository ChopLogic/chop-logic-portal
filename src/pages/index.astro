---
import Footer from "../components/footer/Footer.astro";
import Header from "../components/header/Header.astro";
import MetaData from "../components/meta-data/MetaData.astro";
import { createContentProvider } from "../lib/content/provider";

const provider = createContentProvider();
const { home, siteConfig } = await provider.getHomeIndexContent();
const { siteTitle, footer } = siteConfig;
---

<!doctype html>
<html lang="en">
	<head>
		<MetaData
			siteTitle={siteTitle}
			metaData={home.metaData}
		/>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
				color: rgb(var(--gray-dark));
			}
			.home-hero h1 {
				margin-top: 0;
				text-align: center;
			}
			.home-hero .sub {
				text-align: center;
				color: rgb(var(--gray));
				margin-bottom: 2rem;
			}
			.cms-body :global(.cms-picture img) {
				max-width: 100%;
				height: auto;
				border-radius: 12px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="home-hero">
				<h1>{home.heading}</h1>
				{home.subHeading && <p class="sub">{home.subHeading}</p>}
			</div>
			<div class="cms-body" set:html={home.bodyHtml} />
		</main>
		<Footer content={footer} />
	</body>
</html>
