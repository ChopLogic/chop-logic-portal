---
import Layout from "../layouts/SinglePageWithDynamicContent.astro";
import { createContentProvider } from "../lib/content/provider";

const provider = createContentProvider();
const { home, siteConfig } = await provider.getHomeIndexContent();
const { siteTitle, footer, links } = siteConfig;
const { title, subTitle, content, metaData, documentId, slug, updatedAt } =
	home;
---

<Layout
	siteTitle={siteTitle}
	footer={footer}
	links={links}
	title={title}
	subTitle={subTitle}
	content={content}
	metaData={metaData}
	documentId={documentId}
	slug={slug}
	updatedAt={updatedAt}
/>
