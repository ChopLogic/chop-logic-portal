---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MetaData from "../components/meta-data/MetaData.astro";
import { DEFAULT_META_DATA, DEFAULT_SITE_TITLE } from "../constants/defaults";
import { createContentProvider } from "../lib/content/provider";

const content = createContentProvider();
const home = await content.getSingleton("home");
const siteConfig = await content.getSiteConfig();
const metaData = home?.metaData ?? DEFAULT_META_DATA;
---

<!doctype html>
<html lang="en">
	<head>
		<MetaData
			siteTitle={siteConfig?.siteTitle ?? DEFAULT_SITE_TITLE}
			metaData={metaData}
		/>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
				color: rgb(var(--gray-dark));
			}
			.home-hero h1 {
				margin-top: 0;
				text-align: center;
			}
			.home-hero .sub {
				text-align: center;
				color: rgb(var(--gray));
				margin-bottom: 2rem;
			}
			.cms-body :global(.cms-picture img) {
				max-width: 100%;
				height: auto;
				border-radius: 12px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{
				home ? (
					<>
						<div class="home-hero">
							<h1>{home.heading}</h1>
							{home.subHeading && (
								<p class="sub">{home.subHeading}</p>
							)}
						</div>
						<div class="cms-body" set:html={home.bodyHtml} />
					</>
				) : (
					<p>
						No Home entry found in Strapi (publish the Home single
						type), or
						<code>STRAPI_URL</code> is unreachable.
					</p>
				)
			}
		</main>
		<Footer />
	</body>
</html>
