# Strapi REST base URL (no trailing slash). Local default matches chop-logic-cms config/server.
STRAPI_URL=http://localhost:1337

# Read-only API token from Strapi Admin → Settings → API Tokens.
# Server-only: do NOT prefix with PUBLIC_ (that would expose the token to the browser bundle).
# Optional if the Public role allows the same endpoints, but a token is recommended.
STRAPI_API_TOKEN=
