{
	"name": "chop-logic-portal",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "husky",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check": "biome check . && vitest run",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest --watch"
	},
	"lint-staged": {
		"*.{js,mjs,cjs,ts,tsx,astro,json,jsonc,css}": "biome check --write --no-errors-on-unmatched"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.2",
		"@astrojs/partytown": "^2.1.5",
		"@astrojs/react": "^5.0.1",
		"@astrojs/rss": "^4.0.17",
		"@astrojs/sitemap": "^3.7.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"astro": "^6.0.8",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sharp": "^0.34.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"vitest": "^4.1.0"
	}
}
