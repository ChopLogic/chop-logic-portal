{
	"name": "chop-logic-portal",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "husky",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"astro:check": "astro check",
		"astro:upgrade": "npx @astrojs/upgrade",
		"check": "biome check . && npm run typecheck && npm run astro:check && npm run test:ci",
		"test": "vitest",
		"test:ci": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.3",
		"@astrojs/react": "^5.0.3",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"astro": "^6.1.8",
		"chop-logic-components": "^4.0.3",
		"graphql": "^16.13.2",
		"graphql-request": "^7.4.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@biomejs/biome": "^2.4.12",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@vitest/coverage-v8": "^4.1.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	}
}
